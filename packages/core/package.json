{
  "name": "@zokizuan/satori-core",
  "version": "3.0.0",
  "description": "Core indexing and retrieval engine for Satori's codebase map.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./lancedb": {
      "types": "./dist/lancedb.d.ts",
      "require": "./dist/lancedb.js",
      "default": "./dist/lancedb.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm clean && tsc --build --force",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --import ./src/test-state-root.ts --test --test-concurrency=1 src/**/*.test.ts",
    "test:integration": "pnpm run build && HOME=/tmp node --test --test-concurrency=1 --test-isolation=none ../../tests/integration/*.test.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@lancedb/lancedb": "0.31.0",
    "@vscode/tree-sitter-wasm": "0.3.1",
    "@zilliz/milvus2-sdk-node": "^2.6.17",
    "apache-arrow": "18.1.0",
    "ignore": "^7.0.5",
    "ollama": "^0.5.16",
    "openai": "^5.23.2",
    "oxc-parser": "0.139.0",
    "voyageai": "^0.3.1",
    "web-tree-sitter": "0.26.10",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "assets/tree-sitter/**",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ham-zax/satori.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/ham-zax/satori",
  "bugs": {
    "url": "https://github.com/ham-zax/satori/issues"
  },
  "author": "Hamza (@ham-zax)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
