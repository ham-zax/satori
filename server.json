{
  "schemaVersion": 1,
  "id": "satori",
  "name": "Satori MCP",
  "packageName": "@zokizuan/satori-mcp",
  "version": "4.11.17",
  "description": "Repo-aware MCP tools for AI coding agents: intent search, symbol navigation, advisory call graphs, exact reads, and freshness-aware recovery.",
  "install": {
    "command": "npx",
    "args": [
      "-y",
      "@zokizuan/satori-cli@latest",
      "install",
      "--client",
      "all"
    ],
    "managedRuntime": true
  },
  "clients": {
    "codex": {
      "configPath": "~/.codex/config.toml",
      "configFormat": "toml"
    },
    "claude": {
      "configPath": "~/.claude.json",
      "configFormat": "json"
    },
    "opencode": {
      "configPath": "~/.config/opencode/opencode.json",
      "configFormat": "jsonc"
    }
  }
}
