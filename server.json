{
  "schemaVersion": 1,
  "id": "satori",
  "name": "Satori MCP",
  "packageName": "@zokizuan/satori-mcp",
  "version": "4.11.5",
  "description": "MCP server for Satori with agent-safe semantic search and indexing",
  "install": {
    "command": "npx",
    "args": [
      "-y",
      "@zokizuan/satori-cli@0.4.4",
      "install",
      "--client",
      "all"
    ],
    "managedRuntime": true
  },
  "clients": {
    "codex": {
      "configPath": "~/.codex/config.toml",
      "configFormat": "toml"
    },
    "claude": {
      "configPath": "~/.claude.json",
      "configFormat": "json"
    },
    "opencode": {
      "configPath": "~/.config/opencode/opencode.json",
      "configFormat": "jsonc"
    }
  }
}
