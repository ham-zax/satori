{
    "name": "satori",
    "version": "0.3.1",
    "description": "Satori: sudden-insight semantic code indexing + MCP integration",
    "private": true,
    "scripts": {
        "build": "pnpm -r build",
        "build:cli": "pnpm --filter @zokizuan/satori-cli build",
        "build:core": "pnpm --filter @zokizuan/satori-core build",
        "build:mcp": "pnpm --filter @zokizuan/satori-mcp build",
        "dev": "pnpm -r dev",
        "dev:cli": "pnpm --filter @zokizuan/satori-cli dev",
        "dev:core": "pnpm --filter @zokizuan/satori-core dev",
        "dev:mcp": "pnpm --filter @zokizuan/satori-mcp dev",
        "clean": "pnpm -r clean",
        "lint": "pnpm -r lint",
        "lint:fix": "pnpm -r run lint:fix",
        "typecheck": "pnpm -r run typecheck",
        "release": "pnpm run release:all",
        "release:all": "pnpm run release:core && pnpm run release:mcp && pnpm run release:cli",
        "release:login": "npm login --auth-type=web",
        "release:verify": "npm view @zokizuan/satori-core version && npm view @zokizuan/satori-mcp version && npm view @zokizuan/satori-cli version",
        "release:smoke:cli": "pnpm -C packages/cli release:smoke",
        "release:smoke:mcp": "pnpm -C packages/mcp release:smoke",
        "release:core": "pnpm --filter @zokizuan/satori-core... run build && pnpm --filter @zokizuan/satori-core publish --access public --no-git-checks",
        "release:mcp": "pnpm --filter @zokizuan/satori-mcp... run build && pnpm run release:smoke:mcp && pnpm --filter @zokizuan/satori-mcp publish --access public --no-git-checks",
        "release:cli": "pnpm --filter @zokizuan/satori-cli... run build && pnpm run release:smoke:cli && pnpm --filter @zokizuan/satori-cli publish --access public --no-git-checks",
        "test:integration": "pnpm --filter @zokizuan/satori-core run test:integration",
        "benchmark": "node scripts/build-benchmark.js"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@typescript-eslint/eslint-plugin": "^8.31.1",
        "@typescript-eslint/parser": "^8.31.1",
        "assert": "^2.1.0",
        "browserify-zlib": "^0.2.0",
        "eslint": "^9.25.1",
        "https-browserify": "^1.0.0",
        "os-browserify": "^0.3.1",
        "rimraf": "^6.0.1",
        "stream-http": "^3.2.0",
        "typescript": "^5.8.3",
        "tree-sitter-cli": "^0.25.6",
        "url": "^0.11.4",
        "vm-browserify": "^1.1.2"
    },
    "packageManager": "pnpm@10.28.2",
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=10.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ham-zax/satori.git"
    },
    "homepage": "https://github.com/ham-zax/satori",
    "bugs": {
        "url": "https://github.com/ham-zax/satori/issues"
    },
    "license": "MIT",
    "author": "Hamza (@ham-zax)"
}
