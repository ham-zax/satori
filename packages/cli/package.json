{
  "name": "@zokizuan/satori-cli",
  "version": "1.0.0",
  "description": "Installer and doctor CLI for Satori's repo-aware MCP tools.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "satori-cli": "dist/index.js"
  },
  "scripts": {
    "build": "pnpm clean && tsc --build --force && pnpm fix:bin-perms && node -e \"require('fs').copyFileSync('src/managed-launcher-script.mjs','dist/managed-launcher-script.mjs')\"",
    "dev": "tsx --watch src/index.ts",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "release:smoke": "tsx scripts/release-smoke.ts",
    "fix:bin-perms": "node -e \"const fs=require('fs');try{fs.chmodSync('dist/index.js',0o755);}catch(e){console.error(e);process.exit(1);}\"",
    "prepublishOnly": "pnpm build && pnpm release:smoke",
    "test": "pnpm --filter @zokizuan/satori-mcp build:runtime && node --import tsx --test --test-concurrency=1 src/**/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@zokizuan/satori-core": "workspace:*",
    "@zokizuan/satori-mcp": "workspace:*",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "assets/skills/**/*.md",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ham-zax/satori.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ham-zax/satori",
  "bugs": {
    "url": "https://github.com/ham-zax/satori/issues"
  },
  "author": "Hamza (@ham-zax)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
