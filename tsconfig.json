{
    "compilerOptions": {
        "target": "ES2020",
        "module": "Node16",
        "lib": [
            "ES2020"
        ],
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "Node16",
        "composite": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "incremental": true,
        "tsBuildInfoFile": ".tsbuildinfo"
    },
    "references": [
        {
            "path": "./packages/core"
        },
        {
            "path": "./packages/mcp"
        },
        {
            "path": "./packages/cli"
        }
    ],
    "files": []
}
