{
  "schemaVersion": 1,
  "id": "satori",
  "name": "Satori MCP",
  "packageName": "@zokizuan/satori-mcp",
  "version": "4.4.1",
  "description": "MCP server for Satori with agent-safe semantic search and indexing",
  "install": {
    "command": "npx",
    "args": [
      "-y",
      "@zokizuan/satori-mcp@4.4.1"
    ],
    "startupTimeoutMs": 180000
  },
  "clients": {
    "codex": {
      "configPath": "~/.codex/config.toml",
      "configFormat": "toml"
    },
    "claude": {
      "configPath": "~/.claude/settings.json",
      "configFormat": "json"
    }
  }
}
